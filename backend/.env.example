# ======================================
# Configuração do ambiente (FastAPI + DB)
# ======================================
# Copie este arquivo para `.env` e ajuste os valores.
# O docker-compose lê `backend/.env` automaticamente.

APP_ENV=development
APP_DEBUG=true

# Banco de dados (aponta para o serviço "db" do docker-compose)
DATABASE_URL=postgresql+asyncpg://milhas:milhas@db:5432/milhas

# Cache
REDIS_URL=redis://redis:6379/0

# ======================================
# Credenciais de APIs externas
# ======================================
# Seats.aero — chave Pro vai no header "Partner-Authorization"
SEATS_AERO_API_KEY=coloque_sua_chave_aqui
SEATS_AERO_BASE_URL=https://seats.aero/partnerapi

# Moblix (quando você integrar) — usa OAuth password grant
MOBLIX_USERNAME=
MOBLIX_PASSWORD=
MOBLIX_BASE_URL=https://moblix-api.azurewebsites.net
